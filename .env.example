# PostgreSQL connection string (use Neon's pooled URL in Vercel).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/waypoint?sslmode=require

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# The browser-facing, canonical app URL. Include https:// and no /api/auth
# suffix; Better Auth adds its route automatically.
BETTER_AUTH_URL=http://localhost:3000

# Optional comma-separated extra browser origins (for example a preview URL).
# BETTER_AUTH_TRUSTED_ORIGINS=https://waypoint-git-main-your-team.vercel.app
